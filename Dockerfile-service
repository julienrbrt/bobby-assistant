FROM --platform=$BUILDPLATFORM golang:1.25 AS build

RUN apt-get update && apt-get install -y gcc-multilib

WORKDIR /go/src/app
COPY service/go.mod service/go.sum ./
RUN go mod download
ADD . /go/src/app
ARG TARGETARCH TARGETOS
RUN CGO_ENABLED=1 GOOS=$TARGETOS GOARCH=$TARGETARCH CC=$(echo $TARGETARCH | sed 's/amd64/x86_64/;s/arm64/aarch64/')-linux-gnu-gcc go build -C service -buildvcs=true -o /go/bin/app .

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=build /go/bin/app /app
WORKDIR /data
EXPOSE 8080
ENTRYPOINT ["/app"]
